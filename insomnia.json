    {
      "_id": "req_login",
      "parentId": "fld_auth",
      "modified": 0,
      "created": 0,
      "url": "{{ base_url }}/api/auth/login",
      "name": "Login (setup session)",
      "description": "Login dengan akun SUPERADMIN dari seeder (budi.santoso@umn.ac.id / superadmin_123)",
      "method": "POST",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"budi.santoso@umn.ac.id\",\n  \"password\": \"superadmin_123\"\n}"
      },
      "parameters": [],
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "authentication": {},
      "metaSortKey": 10,
      "_type": "request",
      "settings": {
        "renderRequestBody": true,
        "encodeUrl": true
      },
      "script": {
        "type": "text/javascript",
        "commands": [
          {
            "type": "javascript",
            "value": "const jar = insomnia.getCookieJar();\nconst response = await insomnia.send();\nconst cookies = response.headers.getAll('set-cookie');\nif (cookies.length) {\n  const sessionCookie = cookies.find(c => c.includes('sessionToken'));\n  if (sessionCookie) {\n    const tokenMatch = sessionCookie.match(/sessionToken=([^;]+)/);\n    if (tokenMatch) {\n      insomnia.env.set('sessionToken', tokenMatch[1]);\n    }\n  }\n}\nreturn response;"
          }
        ]
      }
    },
    {
